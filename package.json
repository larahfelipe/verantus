{
  "name": "verantus",
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "larahfelipe",
    "url": "https://github.com/larahfelipe"
  },
  "license": "MIT",
  "repository": "https://github.com/larahfelipe/verantus.git",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.ts --max-warnings=0",
    "lint:fix": "eslint src --ext .vue,.ts --max-warnings=0 --fix",
    "prettier": "prettier --check \"src/**/*.{vue,ts}\"",
    "prettier:fix": "prettier --check \"src/**/*.{vue,ts}\" --write",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "chart.js": "^4.4.3",
    "pinia": "^3.0.4",
    "vue": "^3.4.27",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-helpers": "^1.2.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.26.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "1.6.0",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^2.0.19"
  }
}
